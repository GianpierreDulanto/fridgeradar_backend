DATABASE_URL=
JWT_SECRET=local-dev-secret-change-in-production
ENVIRONMENT=local

# Set your Gemini API key for AI chat feature
GEMINI_API_KEY=

# RF-COM-007: rate limiting (set to "false" to disable, e.g. in tests)
RATE_LIMIT_ENABLED=true

# RF-COM-012: background scan of expiry alerts
ENABLE_SCHEDULER=true
SCAN_INTERVAL_MINUTES=60

# Test database (used by tests/conftest.py)
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fridge_inventory_test
